# Betsy Home production environment template
# Copy this into your deployment provider's Environment Variables panel.
# Do not commit real secrets.

NODE_ENV=production

# App URL
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Generate with:
# openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-long-random-secret

# Supabase / Prisma
# Recommended: Supabase Transaction Pooler for production serverless deployments.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true&connection_limit=5&pool_timeout=60&sslmode=require"

# Optional direct URL for Prisma migrations only, if you use one later.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Stripe test or live keys
# Use test keys for staging, live keys only for production launch.
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Marketplace safety
DEMO_SELLER_FALLBACKS_ENABLED=false
DEMO_ACCOUNTS_ENABLED=false

# Optional email provider later
# RESEND_API_KEY=
# SUPPORT_EMAIL=support@your-domain.com
