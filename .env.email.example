# Betsy Home email notification settings
# Local MVP can run without these; notifications will be logged only.

EMAIL_FROM="Betsy Home <no-reply@your-domain.com>"
SUPPORT_EMAIL="support@your-domain.com"

# Optional future provider
# RESEND_API_KEY=re_replace_me

# In local development, keep this true so emails are printed/logged instead of sent.
EMAIL_LOG_ONLY=true
