generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum ShopStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
  SOLD_OUT
  NEEDS_REVIEW
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum ProductOrigin {
  HANDMADE
  VINTAGE
  SUPPLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

enum RefundRequestStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
}

enum ShippingStatus {
  NOT_REQUIRED
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

enum CustomOrderStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
  CLOSED
}

enum CatalogueTemplate {
  CLEAN_GRID
  LUXURY_LOOKBOOK
  WHOLESALE
  PRICE_LIST
}

enum CatalogueStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String                   @unique
  passwordHash            String?
  role                    UserRole                 @default(CUSTOMER)
  phone                   String?
  avatarUrl               String?
  stripeCustomerId        String?
  shops                   Shop[]                   @relation("SellerShops")
  orders                  Order[]                  @relation("BuyerOrders")
  favorites               Favorite[]
  moodBoards              MoodBoard[]
  reviews                 Review[]                 @relation("BuyerReviews")
  addresses               Address[]
  sentMessages            Message[]                @relation("SentMessages")
  receivedMessages        Message[]                @relation("ReceivedMessages")
  customRequests          CustomOrderRequest[]
  businessProjectRequests BusinessProjectRequest[] @relation("BusinessProjectRequests")
  businessProjectQuotes   BusinessProjectQuote[]   @relation("BusinessProjectQuotes")
  carts                   Cart[]
  emailVerifiedAt         DateTime?
  emailVerificationTokens EmailVerificationToken[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Address {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName    String
  line1       String
  line2       String?
  city        String
  region      String?
  postalCode  String
  countryCode String
  phone       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shop {
  id               String               @id @default(cuid())
  sellerId         String
  seller           User                 @relation("SellerShops", fields: [sellerId], references: [id], onDelete: Cascade)
  shopName         String
  shopSlug         String               @unique
  description      String?
  announcement     String?
  logoUrl          String?
  bannerUrl        String?
  location         String?
  countryCode      String?
  rating           Float                @default(0)
  totalSales       Int                  @default(0)
  stripeAccountId  String?
  status           ShopStatus           @default(DRAFT)
  products         Product[]
  shippingProfiles ShippingProfile[]
  orders           Order[]
  reviews          Review[]
  messages         Message[]
  catalogues       PdfCatalogue[]
  customRequests   CustomOrderRequest[]
  payouts          Payout[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  parentId  String?
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Room {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Style {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                  String               @id @default(cuid())
  shopId              String
  shop                Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title               String
  slug                String               @unique
  description         String
  price               Decimal              @db.Decimal(10, 2)
  salePrice           Decimal?             @db.Decimal(10, 2)
  quantity            Int                  @default(0)
  sku                 String?
  categoryId          String
  category            Category             @relation(fields: [categoryId], references: [id])
  roomId              String?
  room                Room?                @relation(fields: [roomId], references: [id])
  styleId             String?
  style               Style?               @relation(fields: [styleId], references: [id])
  shippingProfileId   String?
  shippingProfile     ShippingProfile?     @relation(fields: [shippingProfileId], references: [id])
  status              ProductStatus        @default(DRAFT)
  productType         ProductType          @default(PHYSICAL)
  origin              ProductOrigin        @default(HANDMADE)
  isCustomizable      Boolean              @default(false)
  personalizationHint String?
  materials           String[]
  dimensions          String?
  careInstructions    String?
  bestFor             String[]
  tags                String[]
  searchKeywords      String[]
  images              ProductImage[]
  variations          ProductVariation[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  favorites           Favorite[]
  moodBoardItems      MoodBoardItem[]
  reviews             Review[]
  collectionProducts  CollectionProduct[]
  customRequests      CustomOrderRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([shopId])
  @@index([categoryId])
  @@index([roomId])
  @@index([styleId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductVariation {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationName   String
  variationValue  String
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)
  stock           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ShippingProfile {
  id                           String                    @id @default(cuid())
  shopId                       String
  shop                         Shop                      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  profileName                  String
  shipsFromCountry             String
  processingTimeMin            Int
  processingTimeMax            Int
  domesticShippingPrice        Decimal?                  @db.Decimal(10, 2)
  internationalShippingEnabled Boolean                   @default(false)
  freeShippingEnabled          Boolean                   @default(false)
  estimatedDeliveryText        String?
  products                     Product[]
  excludedCountries            ShippingExcludedCountry[]
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
}

model ShippingExcludedCountry {
  id                String          @id @default(cuid())
  shippingProfileId String
  shippingProfile   ShippingProfile @relation(fields: [shippingProfileId], references: [id], onDelete: Cascade)
  countryCode       String
  countryName       String
  createdAt         DateTime        @default(now())

  @@unique([shippingProfileId, countryCode])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id                  String   @id @default(cuid())
  cartId              String
  cart                Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  quantity            Int      @default(1)
  selectedVariations  Json?
  personalizationText String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Order {
  id                      String              @id @default(cuid())
  buyerId                 String?
  buyer                   User?               @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: SetNull)
  shopId                  String
  shop                    Shop                @relation(fields: [shopId], references: [id])
  orderNumber             String              @unique
  subtotal                Decimal             @db.Decimal(10, 2)
  shippingTotal           Decimal             @default(0) @db.Decimal(10, 2)
  taxTotal                Decimal             @default(0) @db.Decimal(10, 2)
  platformFee             Decimal             @default(0) @db.Decimal(10, 2)
  total                   Decimal             @db.Decimal(10, 2)
  paymentStatus           PaymentStatus       @default(PENDING)
  shippingStatus          ShippingStatus      @default(NEW)
  shippingAddress         Json?
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  trackingCarrier         String?
  trackingNumber          String?
  trackingUrl             String?
  shippingNote            String?
  buyerConfirmedAt        DateTime?
  buyerDeliveryNote       String?
  refundRequestStatus     RefundRequestStatus @default(NONE)
  refundRequestedAt       DateTime?
  refundReason            String?
  refundResolutionNote    String?
  refundResolvedAt        DateTime?
  refundStripeRefundId    String?
  items                   OrderItem[]
  reviews                 Review[]
  messages                Message[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  titleSnapshot       String
  priceSnapshot       Decimal  @db.Decimal(10, 2)
  quantity            Int
  selectedVariations  Json?
  personalizationText String?
  createdAt           DateTime @default(now())
}

model Review {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId        String
  buyer          User     @relation("BuyerReviews", fields: [buyerId], references: [id], onDelete: Cascade)
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String?
  sellerResponse String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orderId, productId, buyerId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model MoodBoard {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isPublic    Boolean         @default(false)
  items       MoodBoardItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model MoodBoardItem {
  id        String    @id @default(cuid())
  boardId   String
  board     MoodBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([boardId, productId])
}

model Message {
  id            String        @id @default(cuid())
  senderId      String
  sender        User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  shopId        String?
  shop          Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  message       String
  attachmentUrl String?
  status        MessageStatus @default(UNREAD)
  createdAt     DateTime      @default(now())
}

model CustomOrderRequest {
  id                String            @id @default(cuid())
  buyerId           String
  buyer             User              @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  shopId            String
  shop              Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  desiredSize       String?
  desiredColor      String?
  quantity          Int?
  budget            Decimal?          @db.Decimal(10, 2)
  deadline          DateTime?
  shippingCountry   String?
  referenceImageUrl String?
  message           String
  status            CustomOrderStatus @default(OPEN)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model PdfCatalogue {
  id                  String            @id @default(cuid())
  shopId              String
  shop                Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  catalogueTitle      String
  catalogueSubtitle   String?
  templateType        CatalogueTemplate @default(CLEAN_GRID)
  includePrices       Boolean           @default(true)
  includeSku          Boolean           @default(false)
  includeStock        Boolean           @default(false)
  includeQrCodes      Boolean           @default(true)
  includeShippingInfo Boolean           @default(true)
  selectedProductIds  String[]
  pdfFileUrl          String?
  status              CatalogueStatus   @default(DRAFT)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Payout {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  stripePayoutId String?
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
}

model Collection {
  id          String              @id @default(cuid())
  title       String
  slug        String              @unique
  description String?
  imageUrl    String?
  status      ProductStatus       @default(ACTIVE)
  products    CollectionProduct[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([collectionId, productId])
}

enum BusinessProjectStatus {
  SUBMITTED
  REVIEWING
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model BusinessProjectRequest {
  id              String                 @id @default(cuid())
  buyerId         String
  buyer           User                   @relation("BusinessProjectRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  projectName     String
  companyName     String?
  businessType    String?
  projectLocation String?
  neededBy        DateTime?
  budgetRange     String?
  categories      String[]
  quantitySummary String
  message         String
  status          BusinessProjectStatus  @default(SUBMITTED)
  quotes          BusinessProjectQuote[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
}

enum BusinessProjectQuoteStatus {
  SENT
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model BusinessProjectQuote {
  id               String                     @id @default(cuid())
  projectRequestId String
  projectRequest   BusinessProjectRequest     @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           User                       @relation("BusinessProjectQuotes", fields: [sellerId], references: [id], onDelete: Cascade)
  shopId           String?
  shopName         String?
  totalPrice       Decimal                    @db.Decimal(10, 2)
  shippingPrice    Decimal?                   @db.Decimal(10, 2)
  productionDays   Int?
  message          String
  status           BusinessProjectQuoteStatus @default(SENT)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([projectRequestId])
  @@index([sellerId])
  @@index([status])
}
